# Hermes runtime / orchestrator env template.
# Реальные секреты — в bureau/{agent}/.env в репо personal-agent (per-agent isolation).
# Здесь живут только runtime-уровневые переменные (не агентские).

# Корень Hermes runtime (skills, memories, config). По умолчанию ~/.hermes.
HERMES_HOME=

# Путь к personal-agent — orchestrator подгружает llm_router отсюда.
PERSONAL_AGENT_ROOT=/Users/dmitry/Documents/GitHub/personal-agent

# Telegram bot token для оркестратора. Резолвится из bureau/hermes/.env через
# scripts/llm_router._load_agent_env("hermes"). НЕ записывать сюда настоящий
# токен — этот файл только шаблон.
HERMES_TELEGRAM_TOKEN=
