# Copy to /Users/dmitry/Documents/GitHub/oru/secrets/health.env and fill in.
# This file is mounted into the container at runtime — NEVER baked into image.

# --- LLM (own budget, tracked separately from main Hermes) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Telegram (sendMessage only — NO polling, no conflict with main Hermes) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Data sources ---
OURA_ACCESS_TOKEN=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost
STRAVA_REFRESH_TOKEN=

# --- Schedule + behavior ---
# Weekly digest cron (Europe/Belgrade): default Sun 18:00
DIGEST_CRON=0 18 * * SUN

# Health state output file inside shared state/ volume
STATE_FILE=/opt/state/health.json

# --- Workout reminders (resistance bands) ---
# Active program lives in WORKOUTS_STATE_FILE, switch via POST /workout/switch.
# Reminder day-of-week comes from the active program (program_1 = Mon/Wed/Sat,
# program_2 = Tue/Thu/Sat); only the hour is configurable here (Europe/Belgrade).
WORKOUT_ENABLED=true
WORKOUT_HOUR=8
WORKOUTS_STATE_FILE=/opt/state/health-workouts.json

# HTTP API for on-demand /health from main Hermes
HTTP_HOST=0.0.0.0
HTTP_PORT=8001
