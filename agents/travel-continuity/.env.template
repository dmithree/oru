ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

OURA_ACCESS_TOKEN=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost
STRAVA_REFRESH_TOKEN=

# Mount points
MEMORY_DIR=/opt/data/memory
TRAVEL_DIR=/opt/data/travel
STATE_FILE=/opt/state/travel-continuity.json
PERSONAL_CONTEXT_FILE=/opt/state/personal-context.json

# Phase-check tick — runs every N minutes to evaluate trip phase
PHASE_CHECK_CRON=*/30 * * * *
# Pre-trip reminder at this time daily (Europe/Belgrade)
PRETRIP_DAILY_CRON=0 19 * * *

# Home base (for fallback timezone / golden hour outside trips)
HOME_TIMEZONE=Europe/Belgrade
HOME_LATITUDE=44.7866
HOME_LONGITUDE=20.4489

HTTP_HOST=0.0.0.0
HTTP_PORT=8003
