# Daily briefing agent — secrets mounted at runtime.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Health data (same sources as health-agent)
OURA_ACCESS_TOKEN=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost
STRAVA_REFRESH_TOKEN=

# Linear (for stuck tasks)
LINEAR_API_KEY=

# Cron — morning brief at 07:30 + evening prompt at 18:45 Europe/Belgrade
MORNING_CRON=30 7 * * *
EVENING_CRON=45 18 * * *

# Tasks file mounted from personal-agent (read-only)
TASKS_FILE=/opt/data/all-tasks.md

# State
STATE_FILE=/opt/state/daily-briefing.json
PERSONAL_CONTEXT_FILE=/opt/state/personal-context.json

HTTP_HOST=0.0.0.0
HTTP_PORT=8002
